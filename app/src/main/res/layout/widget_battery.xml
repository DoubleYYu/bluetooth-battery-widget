<?xml version="1.0" encoding="utf-8"?>
<!-- iOS-style Bluetooth Battery Widget Layout -->
<!-- 像素级参考 iOS 小部件: 圆角卡片 + 毛玻璃效果 + 简洁设备列表 -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_widget"
    android:padding="16dp">

    <!-- Header: Title + Refresh -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Bluetooth icon -->
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_bluetooth_default"
            android:contentDescription="蓝牙" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="蓝牙设备"
            android:textColor="#1C1C1E"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <!-- Refresh button -->
        <ImageView
            android:id="@+id/btnRefresh"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_refresh"
            android:contentDescription="刷新"
            android:padding="2dp" />
    </LinearLayout>

    <!-- Device list container -->
    <LinearLayout
        android:id="@+id/deviceListContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header"
        android:layout_marginTop="12dp"
        android:orientation="vertical" />

    <!-- Update time -->
    <TextView
        android:id="@+id/tvUpdateTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/deviceListContainer"
        android:layout_marginTop="8dp"
        android:gravity="end"
        android:text="更新于 --:--"
        android:textColor="#8E8E93"
        android:textSize="11sp"
        android:fontFamily="sans-serif-light" />

</RelativeLayout>
